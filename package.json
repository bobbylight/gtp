{
  "name": "gtp",
  "version": "5.3.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/bobbylight/gtp.git"
  },
  "exports": "./lib/index.js",
  "typings": "./lib/index.d.ts",
  "scripts": {
    "clean": "rimraf lib coverage doc",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest --coverage src/",
    "doc": "typedoc --plugin ./typedoc-class-name-fixing-plugin.cjs --excludeExternals --out doc/ --name gtp --exclude **/*.spec.ts src/"
  },
  "files": [
    "lib/"
  ],
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/eslint-plugin": "1.6.18",
    "canvas": "3.2.3",
    "eslint": "9.39.1",
    "eslint-plugin-import": "2.32.0",
    "jsdom": "29.1.1",
    "rimraf": "6.1.3",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
